{
  "name": "@402flow/sdk",
  "version": "0.1.0-alpha.17",
  "description": "Paid HTTP SDK for AI agents with an inspectable prepare/execute flow.",
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "Apache-2.0",
  "author": "402flow",
  "homepage": "https://github.com/402flow/sdk#readme",
  "bugs": {
    "url": "https://github.com/402flow/sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/402flow/sdk.git"
  },
  "keywords": [
    "402flow",
    "sdk",
    "x402",
    "AI",
    "agents",
    "payments"
  ],
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.json",
    "check": "npm run lint && npm test",
    "clean": "node -e \"const fs = require('node:fs'); for (const path of ['dist', 'tsconfig.tsbuildinfo', 'tsconfig.typecheck.tsbuildinfo']) { fs.rmSync(path, { recursive: true, force: true }); }\"",
    "example:openai-harness": "npm run build && node examples/openai-agent-harness.mjs",
    "example:openai-tools-quickstart": "npm run build && node examples/openai-tools-quickstart.mjs",
    "lint": "eslint src vitest.config.ts && npm run typecheck",
    "pack:check": "npm run build && npm pack --dry-run",
    "prepack": "npm run build",
    "scenario:all": "npm run build && node scripts/run-scenarios.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit"
  },
  "dependencies": {
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^22.13.10",
    "@vitest/coverage-v8": "^3.0.8",
    "eslint": "^9.22.0",
    "globals": "^15.15.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1",
    "vitest": "^3.0.8"
  }
}