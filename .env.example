# Copy this file to .env for repo-local SDK example and scenario runs.
# These values belong to the SDK workspace so the examples can target either
# a local control plane or a hosted control plane without reaching into another repo.

OPENAI_API_KEY="..."
X402FLOW_CONTROL_PLANE_BASE_URL="http://localhost:3001"
X402FLOW_ORGANIZATION="acme-labs"
X402FLOW_AGENT="test-agent"

# Set exactly one of the following auth values.
X402FLOW_BOOTSTRAP_KEY="..."
# X402FLOW_RUNTIME_TOKEN="..."

# Optional: first-party scenario-fixture merchant base URL override.
# Defaults to self-hosted demo merchant at http://127.0.0.1:4123.
# Set this to the AWS demo-merchant host during cutover.
# X402FLOW_FIRST_PARTY_MERCHANT_BASE_URL="https://demo-merchant.402flow.ai"
