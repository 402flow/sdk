{
  "name": "@402flow/sdk",
  "version": "0.1.0-alpha.1",
  "description": "Node.js SDK for making paid requests through the 402flow control plane.",
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "Apache-2.0",
  "author": "402flow",
  "homepage": "https://github.com/402flow/sdk#readme",
  "bugs": {
    "url": "https://github.com/402flow/sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/402flow/sdk.git",
    "directory": "packages/sdk"
  },
  "keywords": [
    "402flow",
    "sdk",
    "x402",
    "AI",
    "agents",
    "payments"

  ],
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"const fs = require('node:fs'); for (const path of ['dist', 'tsconfig.tsbuildinfo', 'tsconfig.typecheck.tsbuildinfo']) { fs.rmSync(path, { recursive: true, force: true }); }\"",
    "lint": "eslint src",
    "prepack": "pnpm clean && node -e \"require('node:fs').copyFileSync('../../README.md', 'README.md')\" && pnpm build",
    "postpack": "node -e \"require('node:fs').rmSync('README.md', { force: true })\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit"
  },
  "dependencies": {
    "zod": "^3.24.2"
  }
}